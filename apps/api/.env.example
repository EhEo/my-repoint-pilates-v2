# Copy to .env (gitignored) and fill in real values.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pilates?schema=public

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-bytes-of-random-hex
JWT_EXPIRES_IN=7d

# Initial admin (seed 시 upsert)
ADMIN_EMAIL=admin@pilates.local
ADMIN_PASSWORD=change-me-strong-password

PORT=3000
