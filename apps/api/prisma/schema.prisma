generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum MemberStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

// Class delivery format (formerly named MembershipType — renamed in Phase 3
// to disambiguate from Membership records).
enum ClassType {
  GROUPS
  PRIVATE
  DUET
}

enum ClassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum Role {
  ADMIN
  INSTRUCTOR
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// Models

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id        String       @id @default(uuid())
  name      String
  email     String       @unique
  phone     String
  avatar    String?
  status    MemberStatus @default(ACTIVE)
  joinDate  DateTime     @default(now())
  lastVisit DateTime?
  notes     String?

  memberships  Membership[]
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Count-based membership (횟수권). Single active membership per member is
// enforced in application logic — schema does not unique-constrain this so
// historical (EXPIRED/CANCELLED) records can coexist with a current ACTIVE one.
model Membership {
  id             String           @id @default(uuid())
  memberId       String
  member         Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  totalCount     Int
  remainingCount Int
  startDate      DateTime         @default(now())
  endDate        DateTime
  status         MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId, status])
}

model Instructor {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  specialties String[]
  avatar      String?
  status      String   @default("active") // active, inactive, leave

  classes ClassSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassSession {
  id        String     @id @default(uuid())
  title     String
  date      DateTime // YYYY-MM-DD handled as DateTime
  startTime String // HH:mm
  endTime   String // HH:mm
  capacity  Int
  enrolled  Int        @default(0)
  type      ClassType
  level     ClassLevel
  room      String

  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id        String            @id @default(uuid())
  status    ReservationStatus @default(CONFIRMED)
  timestamp DateTime          @default(now())

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  classSessionId String
  classSession   ClassSession @relation(fields: [classSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
